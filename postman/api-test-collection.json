  "item": [
    {
      "name": "GET-Request 1  SWAPI Single Person",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const data1 = pm.response.json();\r",
              "\r",
              "pm.test(\"Name matches CSV\", () => {\r",
              "    pm.expect(data1.name).to.eql(\r",
              "        pm.iterationData.get(\"personName\")\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"Films count matches CSV\", () => {\r",
              "    pm.expect(data1.films.length).to.eql(\r",
              "        Number(pm.iterationData.get(\"filmCount\"))\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"Height is string\", () => {\r",
              "    pm.expect(data1.height).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Homeworld contains ID\", () => {\r",
              "    pm.expect(data1.homeworld).to.include(\r",
              "        pm.iterationData.get(\"homeworldId\")\r",
              "    );\r",
              "});\r",
              "\r",
              "// Chaining variables\r",
              "pm.environment.set(\"homeworldUrl\", data1.homeworld);\r",
              "pm.environment.set(\"firstFilmUrl\", data1.films[0]);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{swapiBase}}/people/{{personId}}",
          "host": [
            "{{swapiBase}}"
          ],
          "path": [
            "people",
            "{{personId}}"
          ]
        }
      },
      "response": []
    },
