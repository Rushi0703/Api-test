    {
      "name": "GET-Request 4-AIC Artwork Lookup",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "const data2 = response.data;\r",
              "\r",
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Artwork ID matches CSV\", () => {\r",
              "    pm.expect(data2.id).to.eql(\r",
              "        Number(pm.iterationData.get(\"artworkId\"))\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"Artist contains expected artist\", () => {\r",
              "    pm.expect(data2.artist_display).to.include(\r",
              "        pm.iterationData.get(\"expectedArtist\")\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"Title is not empty\", () => {\r",
              "    pm.expect(data2.title).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"medium_display key exists\", () => {\r",
              "    pm.expect(data2).to.have.property(\"medium_display\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{aicBase}}/artworks/{{artworkId}}?fields=id,title,artist_display,date_display,medium_display",
          "host": [
            "{{aicBase}}"
          ],
          "path": [
            "artworks",
            "{{artworkId}}"
          ],
          "query": [
            {
              "key": "fields",
              "value": "id,title,artist_display,date_display,medium_display"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET-Request 5-AIC Pagination Validation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Data length is 10\", () => {\r",
              "    pm.expect(response.data.length).to.eql(12);\r",
              "});\r",
              "\r",
              "pm.test(\"Total > 100000\", () => {\r",
              "    pm.expect(response.pagination.total).to.be.above(100000);\r",
              "});\r",
              "\r",
              "pm.test(\"Current page is 1\", () => {\r",
              "    pm.expect(response.pagination.current_page).to.eql(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Total pages > current page\", () => {\r",
              "    pm.expect(response.pagination.total_pages)\r",
              "      .to.be.above(response.pagination.current_page);\r",
              "});\r",
              "\r",
              "response.data.forEach(item => {\r",
              "    pm.expect(item.id).to.be.a(\"number\");\r",
              "    pm.expect(item.title).to.be.a(\"string\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{aicBase}}/artworks?page=1&limit;=10&fields;=id,title,artist_display",
          "host": [
            "{{aicBase}}"
          ],
          "path": [
            "artworks"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit;",
              "value": "10"
            },
            {
              "key": "fields;",
              "value": "id,title,artist_display"
            }
          ]
        }
      },
      "response": []
    },
