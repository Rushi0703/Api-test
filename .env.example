//Base URL based on the environment
BASE_URL = ''

//Configurations
SEND_TEAMS_MESSAGE=false
SEND_SLACK_MESSAGE=false
REPORT_TO_JIRA=false 
REPORT_TO_XRAY=false
//Use of below variable will create many response and request logs
ATTACH_BROWSER_LOGS = false

//Anthropic api kwy for AI reasoning in integratiosn
ANTHROPIC_API_KEY = 'your-anthropic-api-key-1234567890'

//Jira Configuration
JIRA_BASE_URL = 'https://yourcompany.atlassian.net'
JIRA_EMAIL = 'your.jira.email@example.com'
JIRA_API_TOKEN = 'your-jira-api-token'
JIRA_PROJECT_KEY = 'your-project-key'

//X-ray Configuration
XRAY_BASE_URL = 'https://api.xrayapp.io'
XRAY_CLIENT_ID = 'your-xray-client-id'
XRAY_CLIENT_SECRET = 'your-xray-client-secret'
XRAY_PROJECT_KEY = 'your-xray-project-key'
XRAY_TEST_EXECUTION_ISSUE_TYPE = 'Test Execution'

//Slack Integration
SLACK_ACCESS_TOKEN = 'your-slack-access-token'
SLACK_CHANNEL_NAME = 'your-slack-channel-name'

//Teams Integration
TEAMS_WEBHOOK_URL='https://your-teams-webhook-url.com'

//Databse Integration
DB_USERNAME = 'your-db-username'
DB_PASSWORD = 'your-db-password'
DB_SERVER_NAME = 'your-db-server-name'
DB_PORT = 5432
DB_NAME = 'your-db-name'


# SonarQube GitHub Secrets - Copy this template to configure your repository
# For SonarQube Cloud (https://sonarcloud.io):
# SONAR_HOST_URL=https://sonarcloud.io
# SONAR_LOGIN=squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxx (your generated token)
# SONAR_PROJECT_KEY=your-org_your-project-key
# SONAR_ORGANIZATION = your-org
# For Self-Hosted SonarQube:
# SONAR_HOST_URL=https://your-sonarqube-server.com
# SONAR_LOGIN=squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxx (your generated token)
# SONAR_PROJECT_KEY=YOUR_PROJECT_KEY
# SONAR_ORGANIZATION = your-org